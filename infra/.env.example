# Для docker compose из корня репозитория используйте:
# docker compose --env-file infra/.env -f infra/docker-compose.yml up --build -d

# Переменные приложения
APP_TITLE=Система бронирования мест в кафе.
APP_DESCRIPTION=Забронируй место в кафе в любой точке мира!
APP_PORT=8000
APP_DOMAIN=your-domain.example.com
SERVER_IP=77.91.84.94
DOCKERHUB_USERNAME=your-dockerhub-username
DOCKERHUB_TOKEN=
DOCKER_PASSWORD=

# Логирование
SECRET=supasecret
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
LOG_ROTATION=10 MB
LOG_RETENTION=10 files

# Переменные JWT
SECRET_KEY=your-super-secret-key-change-in-prod
REFRESH_SECRET_KEY=your-refresh-secret-key-change-in-prod
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Переменные media
MEDIA_DIR=media
MAX_IMAGE_SIZE=5242880
ALLOWED_IMAGE_TYPES=["image/jpeg", "image/png"]
ALLOWED_EXTENTIONS=[".jpg", ".jpeg", ".png"]
JPEG_QUALITY=85

# Пагинация
DEFAULT_PAGE_LIMIT=50
MAX_PAGE_LIMIT=1000

#RabbitMQ
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
RABBITMQ_USER=admin
RABBITMQ_PASS=change-me-rabbit-password
RABBITMQ_VHOST=/
RABBITMQ_HEARTBEAT=600
RABBITMQ_CONNECTION_ATTEMPTS=5
RABBITMQ_DELIVERY_MODE=2
DOCKER_RABBITMQ_HOST=rabbitmq

# Celery
# BROKER_URL intentionally omitted to avoid credential drift.
# Celery always derives broker URL from RABBITMQ_USER / RABBITMQ_PASS /
# DOCKER_RABBITMQ_HOST / RABBITMQ_PORT / RABBITMQ_VHOST.
# In production, infra/.env is the single source of truth for runtime settings.
# docker-compose.production.yml reads DOCKERHUB_USERNAME directly from infra/.env.
# For private Docker Hub images on the server, set either DOCKERHUB_TOKEN
# or DOCKER_PASSWORD so the deploy step can run docker login before pull.
BACKEND_RESULT=rpc://

# SMTP for local development via smtp4dev
SMTP_HOST=smtp4dev
SMTP_PORT=25
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=booking@booking.com
SMTP_USE_TLS=False
SMTP_USE_SSL=False
SMTP4DEV_WEB_PORT=5001
SMTP4DEV_SMTP_PORT=25
SMTP4DEV_IMAP_PORT=143
SMTP4DEV_POP3_PORT=110

# SMTP for Yandex production setup
# Use an app password, not the mailbox login password.
# SMTP_HOST=smtp.yandex.ru
# SMTP_PORT=465
# SMTP_USER=your_mailbox@yandex.ru
# SMTP_PASSWORD=your_app_password
# SMTP_FROM_EMAIL=your_mailbox@yandex.ru
# SMTP_USE_TLS=false
# SMTP_USE_SSL=true

# Flower
FLOWER_PORT=5555
FLOWER_BASIC_AUTH=admin:admin
# Optional override. Usually do not set it: Flower now derives broker API
# from RABBITMQ_USER / RABBITMQ_PASS / DOCKER_RABBITMQ_HOST automatically.
# FLOWER_BROKER_API=http://admin:adminpass@rabbitmq:15672/api/
FLOWER_URL_PREFIX=

# PostgreSQL
# SYNC_DATABASE_URL is intentionally omitted to avoid drifting away from the
# POSTGRES_* variables. The app and Celery derive database URLs automatically.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=booking_db
POSTGRES_PORT=5432
POSTGRES_HOST=localhost
DOCKER_POSTGRES_HOST=db

#Init DB
# Суперпользователь
FIRST_SUPERUSER_EMAIL=admin@example.com
FIRST_SUPERUSER_PASSWORD=Strongadmin123
FIRST_SUPERUSER_PHONENUMBER=+79000000001

# Менеджер
FIRST_MANAGER_EMAIL=manager@example.com
FIRST_MANAGER_PASSWORD=Strongmanager123
FIRST_MANAGER_PHONENUMBER=+79000000002

# Обычный пользователь
FIRST_USER_EMAIL=firstuser@example.com
FIRST_USER_PASSWORD=Stronguser123
FIRST_USER_PHONENUMBER=+79000000003
